---
// Importamos las nuevas fuentes modernas
import '@fontsource/poppins';
import '@fontsource/open-sans';

interface Props {
    title: string;
    description?: string;
    image?: string;
    canonical?: string;
    noindex?: boolean;
}

const {
    title,
    description = 'Kerala Tours AQP - Viajes exclusivos',
    image = '/og_imagen.webp',
    canonical,
    noindex = false
} = Astro.props;

const siteName = 'Kerala Tours AQP';
const author = 'Rodrigo Prieto';
const url = canonical ?? Astro.url.href;
const imageUrl = new URL(image, Astro.url).href;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';

const organizationSchema = {
    '@context': 'https://schema.org',
    '@type': 'TravelAgency',
    name: siteName,
    url,
    logo: new URL('/favicon.svg', Astro.url).href
};
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="canonical" href={url} />
        
        <title>{title}</title>
        
        <meta name="description" content={description} />
        <meta name="keywords" content="Viajes, Turismo, Arequipa, Kerala, Tours" />
        <meta name="author" content={author} />
        <meta name="robots" content={robots} />
        <meta name="googlebot" content={robots} />

        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:locale" content="es_PE" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={url} />
        <meta property="og:image" content={imageUrl} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />

        <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    </head>
    <body>
        <slot />

        <!-- SCRIPT CORREGIDO: Ahora sí detecta las subidas y bajadas perfectamente -->
        <script>
            const sections = document.querySelectorAll('section[data-theme]');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    // Solo cambia de color si la sección está ocupando buena parte de la pantalla
                    if(entry.isIntersecting) {
                        const theme = entry.target.getAttribute('data-theme');
                        
                        if(theme === 'light') {
                            // Gris Grafito: Se nota bastante la diferencia, pero sigue siendo oscuro y premium
                            document.documentElement.style.setProperty('--bg-dark', '#331510');
                        } else if (theme === 'dark') {
                            // Regresa a tu color original
                            document.documentElement.style.setProperty('--bg-dark', '#1a1a1a');
                        }
                    }
                });
            }, { 
                threshold: 0.4 // Tiene que estar viendo el 40% de la sección para cambiar
            });

            sections.forEach(section => observer.observe(section));
        </script>
    </body>
</html>

<style is:global>
    @import 'tailwindcss';
    @import 'tailwind-animations';

    :root {
        --font-heading: 'Poppins', sans-serif;
        --font-body: 'Open Sans', sans-serif;
        
        --color-primary: #AE333C;
        --color-secondary: #FF9A09;
        --bg-dark: #1a1a1a;
    }

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        font-family: var(--font-body);
        background-color: var(--bg-dark);
        color: #e5e5e5;
        scroll-behavior: smooth;
        
        transition: background-color 0.8s ease-in-out;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 700; 
    }

    * {
        box-sizing: border-box;
    }
</style>