---
// src/sections/Header.astro
const navItems = [
  { name: "Inicio", href: "/" }, 
  { name: "Destinos", href: "/#destinos" }, 
  { name: "Paquetes", href: "/paquetes" },
  { name: "Nosotros", href: "/#nosotros" },
];
---

<header
  id="landing-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent pointer-events-none"
>
  <div id="header-inner" class="relative z-[60] max-w-7xl mx-auto px-6 py-4 flex justify-between items-center pointer-events-auto">
    
    <a href="/" class="flex items-center gap-2">
       <span class="animate-jiggle">
        <img src="/logo.png" alt="Kerala Tours Logo" class="h-16 md:h-24 w-auto object-contain drop-shadow-lg">
      </span>
    </a>
   
    <nav class="hidden md:flex gap-8 items-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-astro-reload={item.href.includes('/#') ? "true" : "false"}
          class="text-lg font-medium text-gray-200 hover:text-[#FF9A09] transition-colors relative group"
        >
          {item.name}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FF9A09] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <a
        href="#contacto"
        class="bg-gradient-to-r from-[#AE333C] to-[#FF9A09] hover:from-[#CD7634] hover:to-[#C46A71] text-white px-6 py-2.5 rounded-full font-bold transition-all transform hover:scale-105 shadow-lg shadow-[#AE333C]/40"
      >
        Reservar
      </a>
    </div>

    <button id="menu-btn" class="md:hidden text-white focus:outline-none transition-transform active:scale-95">
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 hidden transition-transform duration-300 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div
  id="mobile-menu"
  class="fixed top-0 left-0 w-full h-[100dvh] bg-black/70 backdrop-blur-xl flex flex-col justify-center items-center gap-8 text-xl translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden z-50 pt-20 pointer-events-auto"
  >
    {navItems.map((item) => (
      <a href={item.href} class="mobile-link text-white hover:text-[#FF9A09] font-bold text-3xl transition-colors">
        {item.name}
      </a>
    ))}
    
    <div class="w-16 h-[1px] bg-white/20 my-2"></div>
    
    <a href="#contacto" class="mobile-link bg-gradient-to-r from-[#AE333C] to-[#FF9A09] text-white px-8 py-3 rounded-full font-bold shadow-lg shadow-[#AE333C]/40 flex items-center gap-2">
      Reservar Ahora
    </a>
  </div>
</header>

<script>
  const header = document.getElementById("landing-header");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("bg-black/50", "backdrop-blur-md", "py-2"); 
      header?.classList.remove("bg-transparent", "py-4");
    } else {
      header?.classList.add("bg-transparent", "py-4");
      header?.classList.remove("bg-black/50", "backdrop-blur-md", "py-2");
    }
  });

  const toggleMenu = () => {
    mobileMenu?.classList.toggle("translate-x-full");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    iconClose?.classList.toggle("rotate-90");
    document.body.classList.toggle("overflow-hidden");
  };

  menuBtn?.addEventListener("click", toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener("click", toggleMenu);
  });
</script>