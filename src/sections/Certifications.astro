---
// src/sections/Certifications.astro
import { Image } from 'astro:assets';

// IMPORTAMOS LAS IMÁGENES
import minceturk from '../assets/logos/minceturk.png';
import safeTravels from '../assets/logos/safe_travels.png';
import promPeru from '../assets/logos/prom_peru.png';
import iPeru from '../assets/logos/logo_iPeru.png';

const certs = [
  {
    name: "MINCETUR",
    desc: "Directorio Nacional",
    image: minceturk
  },
  {
    name: "Safe Travels",
    desc: "Sello de Bioseguridad",
    image: safeTravels
  },
  {
    name: "PromPerú",
    desc: "Turismo Oficial",
    image: promPeru
  },
  {
    name: "iPerú",
    desc: "Asistencia al Turista",
    image: iPeru
  }
];
---

<section
  id="certifications"
  class="py-12 bg-[#050505] border-y border-white/5 relative z-40 scroll-mt-24 md:scroll-mt-32"
>
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="text-center mb-10">
      <p class="text-sm font-semibold text-gray-500 uppercase tracking-[0.2em]">Agencia formal acreditada por</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {certs.map((cert) => (
        <div class="group flex flex-col items-center justify-center text-center p-4 cursor-default">
          
       {/* CAJITA BLANCA SUAVIZADA (Soft Glass) */}
       <div class="h-20 w-full max-w-[160px] bg-white/85 backdrop-blur-sm rounded-2xl flex items-center justify-center p-4 mb-4 shadow-lg border border-white/20 group-hover:bg-white group-hover:shadow-[0_0_20px_rgba(255,255,255,0.2)] group-hover:-translate-y-1 transition-all duration-500">
             {cert.image && (
                <Image 
                  src={cert.image} 
                  alt={`Logo de ${cert.name}`} 
                  class="h-full w-full object-contain" 
                />
             )}
          </div>
          
          <h3 class="text-white font-bold text-sm md:text-base tracking-wide">{cert.name}</h3>
          <p class="text-xs text-gray-500 mt-1">{cert.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>