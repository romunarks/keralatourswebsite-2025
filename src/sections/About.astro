---
// src/sections/About.astro
import { Image } from 'astro:assets';
// Asegúrate de poner una foto horizontal de tu equipo o un grupo de turistas felices
import imgNosotros from '../assets/hero/arequipa_city.webp'; 
---

<section id="nosotros" class="py-12 bg-[#0a0a0a] relative border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <div class="bg-white/[0.02] border border-white/10 rounded-3xl overflow-hidden flex flex-col lg:flex-row shadow-2xl">
      
      <!-- Lado Izquierdo: La Historia (Kerala y la Familia Munar) -->
      <div class="lg:w-3/5 p-8 md:p-12 flex flex-col justify-center">
        <span class="text-[#FF9A09] font-bold tracking-wider uppercase text-xs mb-3 block">Desde el 2011</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4">
          La magia de Kerala, <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#AE333C] to-[#FF9A09]">respaldada por la familia Munar.</span>
        </h2>
        <p class="text-gray-300 text-base leading-relaxed mb-4">
          Fundada en 2011, <strong>Kerala Tours E.I.R.L.</strong> nació con una profunda experiencia en turismo sostenible hacia el extranjero. Hoy, nos expandimos con orgullo hacia el turismo receptivo para mostrarle al mundo la majestuosidad de nuestra tierra.
        </p>
        <p class="text-gray-400 text-sm leading-relaxed mb-8 italic border-l-2 border-[#FF9A09] pl-4">
          ¿Por qué Kerala? Es una hermosa coincidencia del destino. Nuestro apellido familiar es Munar, al igual que la mágica e inolvidable región de Munnar ubicada en el estado de Kerala, India. Llevamos la esencia de los viajes en nuestra identidad.
        </p>
        
        <!-- Especialidades -->
        <h3 class="text-white font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Nuestras Especialidades
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-gray-300">
          <div class="flex items-center gap-2">
            <span class="text-[#AE333C] font-bold">•</span> Viajes de Estudio y Promociones
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[#AE333C] font-bold">•</span> Colegios y Universidades
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[#AE333C] font-bold">•</span> Turismo para Adultos Mayores
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[#AE333C] font-bold">•</span> Turismo Sostenible
          </div>
        </div>
      </div>

      <!-- Lado Derecho: Imagen -->
      <div class="lg:w-2/5 relative min-h-[300px] lg:min-h-full bg-black/50">
        <Image 
          src={imgNosotros} 
          alt="Familia Kerala Tours Munar"
          width={600}
          height={800}
          class="absolute inset-0 w-full h-full object-cover opacity-80"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a] to-transparent lg:w-1/3"></div>
      </div>

    </div>
  </div>
</section>