---
// src/sections/Catalog.astro
import { Image } from 'astro:assets';

// Conectamos tu base de datos TypeScript
import { paquetes } from '../data/paquetes.ts'; 
---

<section class="py-12 md:py-20 relative overflow-hidden">
  
  <div class="max-w-[1400px] mx-auto px-6 relative z-10">
    
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">
        Explora nuestro <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#AE333C] to-[#FF9A09]">Catálogo</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Encuentra el viaje perfecto para ti. Filtra por destino y descubre las maravillas que tenemos preparadas.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button class="catalog-btn active px-6 py-2 rounded-full font-semibold text-sm transition-all bg-gradient-to-r from-[#AE333C] to-[#FF9A09] text-white shadow-lg" data-filter="todos">
        Todos
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="arequipa">
        Arequipa
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="cusco">
        Cusco
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="internacional">
        Internacionales
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 xl:gap-8">
      {paquetes.map((pkg) => (
        <article class="catalog-card group relative flex flex-col bg-white/[0.03] border border-white/10 rounded-3xl overflow-hidden hover:bg-white/[0.05] hover:border-white/20 transition-all duration-500 hover:-translate-y-2" data-category={pkg.category}>
          
          <div class="relative h-56 overflow-hidden">
            <Image 
              src={pkg.img}
              alt={pkg.title}
              width={600}
              height={400}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class={`absolute top-4 left-4 ${pkg.tagColor} text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-full`}>
              {pkg.tag}
            </div>
          </div>

          <div class="flex flex-col flex-grow p-6">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-[#FF9A09] transition-colors">{pkg.title}</h3>
            
            <div class="flex items-center gap-4 text-xs text-gray-400 mb-4">
               <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#FF9A09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> {pkg.duration}</span>
            </div>

            <p class="text-sm text-gray-400 mb-6 flex-grow leading-relaxed">{pkg.desc}</p>
            
            <div class="flex items-end justify-between border-t border-white/10 pt-5 mt-auto">
              <div>
                <p class="text-[11px] text-gray-500 uppercase font-semibold mb-1">Desde</p>
                <p class="text-xl font-bold text-white">{pkg.price}</p>
              </div>
              
              <a href={`/tour/${pkg.slug}`} class="px-5 py-2.5 rounded-full bg-white/10 text-white text-sm font-semibold hover:bg-gradient-to-r hover:from-[#AE333C] hover:to-[#FF9A09] transition-all shadow-lg active:scale-95">
                Ver Tour
              </a>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.catalog-btn');
  const cards = document.querySelectorAll('.catalog-card') as NodeListOf<HTMLElement>;

  const activeClasses = ['bg-gradient-to-r', 'from-[#AE333C]', 'to-[#FF9A09]', 'text-white', 'shadow-lg', 'border-transparent'];
  const inactiveClasses = ['bg-white/5', 'border', 'border-white/20', 'text-gray-300', 'hover:bg-white/10'];

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');

      buttons.forEach(btn => {
        btn.classList.remove(...activeClasses);
        btn.classList.add(...inactiveClasses);
      });
      button.classList.remove(...inactiveClasses);
      button.classList.add(...activeClasses);

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        
        if (filter === 'todos' || category === filter) {
          card.style.display = 'flex';
          setTimeout(() => card.style.opacity = '1', 50);
        } else {
          card.style.display = 'none';
          card.style.opacity = '0';
        }
      });
    });
  });
</script>