---
// src/sections/Catalog.astro
import { Image } from 'astro:assets';

// Conectamos tu base de datos TypeScript
import { paquetes } from '../data/paquetes.ts'; 
---

<section class="py-12 md:py-20 relative overflow-hidden">
  
  <div class="max-w-[1400px] mx-auto px-6 relative z-10">
    
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">
        Explora nuestro <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#AE333C] to-[#FF9A09]">Catálogo</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Encuentra el viaje perfecto para ti. Filtra por destino y descubre las maravillas que tenemos preparadas.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button class="catalog-btn active px-6 py-2 rounded-full font-semibold text-sm transition-all bg-gradient-to-r from-[#AE333C] to-[#FF9A09] text-white shadow-lg" data-filter="todos">
        Todos
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="arequipa">
        Arequipa
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="cusco">
        Cusco
      </button>
      <button class="catalog-btn px-6 py-2 rounded-full font-semibold text-sm transition-all bg-white/5 border border-white/20 text-gray-300 hover:bg-white/10" data-filter="internacional">
        Internacionales
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 xl:gap-8">
      {paquetes.map((pkg) => (
        <article class="catalog-card group relative h-[450px] flex flex-col rounded-3xl overflow-hidden border border-white/10 hover:border-white/20 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.7)]" data-category={pkg.category}>
          
          <!-- 1. Imagen de Fondo (Cubre toda la tarjeta) -->
          <Image 
            src={pkg.img}
            alt={pkg.title}
            width={600}
            height={600}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 will-change-transform"
          />
          
          <!-- 2. Degradado Oscuro (Para leer el texto) -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/70 to-transparent opacity-90 transition-opacity duration-500"></div>

          <!-- 3. Etiquetas Superiores -->
          <div class="relative z-10 flex justify-between items-start p-6">
            <div class={`absolute top-6 left-6 ${pkg.tagColor} text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-full shadow-lg`}>
              {pkg.tag}
            </div>
            
            <div class="absolute top-6 right-6 bg-black/50 backdrop-blur-md text-white text-xs font-semibold px-3 py-1.5 rounded-full border border-white/10 flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-[#FF9A09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {pkg.duration}
            </div>
          </div>

          <!-- 4. Contenido Inferior y TU BOTÓN ORIGINAL -->
          <div class="relative z-10 flex flex-col justify-end flex-grow p-6 mt-auto">
            <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-[#FF9A09] transition-colors drop-shadow-md">{pkg.title}</h3>
            
            <p class="text-sm text-gray-300 mb-5 line-clamp-2 leading-relaxed drop-shadow-md">{pkg.desc}</p>
            
            <div class="flex items-end justify-between border-t border-white/10 pt-5 mt-auto">
              <!-- TU PRECIO -->
              <div>
                <p class="text-[11px] text-gray-400 uppercase tracking-widest font-semibold mb-1">Desde</p>
                <p class="text-2xl font-bold text-white drop-shadow-md">{pkg.price}</p>
              </div>
              
              <!-- TU BOTÓN ORIGINAL KERALA TOURS -->
              <a href={`/tour/${pkg.slug}`} class="px-5 py-2.5 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-white text-sm font-semibold hover:bg-gradient-to-r hover:from-[#AE333C] hover:to-[#FF9A09] transition-all shadow-lg active:scale-95">
                Ver Tour
              </a>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.catalog-btn');
  const cards = document.querySelectorAll('.catalog-card') as NodeListOf<HTMLElement>;

  const activeClasses = ['bg-gradient-to-r', 'from-[#AE333C]', 'to-[#FF9A09]', 'text-white', 'shadow-lg', 'border-transparent'];
  const inactiveClasses = ['bg-white/5', 'border', 'border-white/20', 'text-gray-300', 'hover:bg-white/10'];

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');

      buttons.forEach(btn => {
        btn.classList.remove(...activeClasses);
        btn.classList.add(...inactiveClasses);
      });
      button.classList.remove(...inactiveClasses);
      button.classList.add(...activeClasses);

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        
        if (filter === 'todos' || category === filter) {
          card.style.display = 'flex';
          setTimeout(() => card.style.opacity = '1', 50);
        } else {
          card.style.display = 'none';
          card.style.opacity = '0';
        }
      });
    });
  });
</script>