---
// src/pages/tour/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../sections/Header.astro';
import Footer from '../../sections/Footer.astro';
import { Image } from 'astro:assets';

// Importamos la base de datos de TypeScript
import { paquetes } from '../../data/paquetes.ts';

export async function getStaticPaths() {
  return paquetes.map((pkg) => {
    return {
      params: { slug: pkg.slug },
      props: { pkg },
    };
  });
}

const { pkg } = Astro.props;
---

<Layout title={`${pkg.title} - Kerala Tours AQP`}>
  <Header />

  <main class="bg-[#0a0a0a] min-h-screen text-gray-200 font-sans pb-16">
    
    <section class="relative w-full h-[60vh] min-h-[500px] flex items-end pb-16 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <Image 
          src={pkg.img} 
          alt={pkg.title}
          width={1920}
          height={1080}
          quality={100}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/50 to-black/50"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 w-full animate-fade-in-up mt-24">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-white shadow-lg ${pkg.tagColor}`}>
            {pkg.tag}
          </span>
          <span class="px-3 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-xs font-bold uppercase tracking-wider text-white">
            {pkg.category}
          </span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold text-white tracking-tight leading-tight">
          {pkg.title}
        </h1>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 relative z-20 mt-[-40px] md:mt-[-60px]">
      <div class="flex flex-col md:grid md:grid-cols-3 md:gap-12">
        
        <div class="order-2 md:order-1 md:col-span-2 space-y-12">
          
          <div class="bg-white/[0.03] border border-white/10 rounded-3xl p-6 md:p-8 backdrop-blur-sm shadow-xl mt-8 md:mt-0">
            <h2 class="text-2xl font-bold text-white mb-5 flex items-center gap-3">
              <svg class="w-7 h-7 min-w-[28px] text-[#FF9A09] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10l8 4"/><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Visión General del Viaje
            </h2>
            <p class="text-gray-300 leading-relaxed text-lg">
              {pkg.desc}
            </p>
          </div>

          <div class="bg-white/[0.03] border border-white/10 rounded-3xl p-6 md:p-8 backdrop-blur-sm shadow-xl">
            <h2 class="text-2xl font-bold text-white mb-5 flex items-center gap-3">
              <svg class="w-7 h-7 min-w-[28px] text-emerald-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              ¿Qué Incluye este Paquete?
            </h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-gray-300">
              {pkg.included && pkg.included.map(item => (
                <li class="flex items-start gap-3">
                  <span class="text-emerald-500 font-black mt-0.5 flex-shrink-0">✓</span> 
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          {pkg.itinerary && pkg.itinerary.length > 0 && (
            <div class="bg-white/[0.03] border border-white/10 rounded-3xl p-6 md:p-8 backdrop-blur-sm shadow-xl">
              <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
                <svg class="w-7 h-7 min-w-[28px] text-[#AE333C] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Itinerario Detallado
              </h2>
              <div class="space-y-6 relative pl-8 border-l-2 border-white/10 ml-4">
                {pkg.itinerary.map(item => (
                  <div class="relative pb-8 group">
                    <div class="absolute -left-[41px] top-1 h-6 w-6 rounded-full border-4 border-[#0a0a0a] bg-white/10 group-hover:scale-110 group-hover:bg-gradient-to-r group-hover:from-[#AE333C] group-hover:to-[#FF9A09] transition-all"></div>
                    <p class="text-sm font-semibold text-[#FF9A09] uppercase tracking-wider mb-1 group-hover:text-white transition">{item.day}</p>
                    <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                    <p class="text-gray-400 text-base leading-relaxed">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>

        <div class="order-1 md:order-2 space-y-8">
          <div class="sticky top-32 bg-white/[0.03] border border-white/10 rounded-3xl p-8 backdrop-blur-sm shadow-2xl flex flex-col gap-6">
            
            <div class="flex flex-col gap-1">
              <p class="text-sm text-gray-400 uppercase tracking-widest font-semibold mb-1">Precio Desde</p>
              <p class="text-5xl font-bold text-white tracking-tight">{pkg.price}</p>
              <p class="text-xs text-gray-500">*Por persona en habitación doble.</p>
            </div>

            <div class="border-y border-white/10 py-5 space-y-4">
              <div class="flex items-center justify-between text-gray-300">
                <span class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-[#FF9A09] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  Duración
                </span>
                <span class="font-semibold text-white">{pkg.duration}</span>
              </div>
              <div class="flex items-center justify-between text-gray-300">
                <span class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-[#FF9A09] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="10"/></svg>
                  Categoría
                </span>
                <span class="font-semibold text-white capitalize">{pkg.category}</span>
              </div>
            </div>

            <a 
              href={`https://wa.me/51953530209?text=Hola%20Kerala%20Tours,%20quiero%20solicitar%20cotización%20para%20el%20paquete:%20*${pkg.title}*`}
              target="_blank"
              class="w-full flex items-center justify-center gap-2 bg-gradient-to-r from-[#AE333C] to-[#FF9A09] text-white font-bold py-4 rounded-xl hover:scale-[1.02] transition-transform shadow-lg shadow-[#AE333C]/30 text-center"
            >
              Solicitar Cotización por WhatsApp
            </a>
            <p class="text-xs text-center text-gray-500 mt-[-10px]">Atención inmediata y personalizada.</p>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>